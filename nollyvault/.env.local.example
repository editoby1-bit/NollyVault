# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Get these from https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── ADMIN ────────────────────────────────────────────────────────────────────
# Comma-separated list of emails allowed to use /admin and the admin API routes
# (upload, royalties, legacy fund, referrals, whoami). No default — if this is
# empty, every admin action is denied for everyone, including you.
ADMIN_EMAILS=you@example.com,cofounder@example.com



# ─── BUNNY.NET (replaces Cloudflare Stream — ~12x cheaper) ───────────────────
# Get from https://dash.bunny.net → Stream → Your Library → API
# Step 1: Create a free account at bunny.net
# Step 2: Go to Stream → Add Video Library → name it "naijarewind"  
# Step 3: In library settings, copy the values below
BUNNY_LIBRARY_ID=your_library_id_here
BUNNY_STREAM_KEY=your_library_api_key_here
BUNNY_CDN_HOSTNAME=naijarewind.b-cdn.net
# Step 4: Main account API key (from Account → API Key)
BUNNY_API_KEY=your_account_api_key_here
# Public (needed for in-app player)
NEXT_PUBLIC_BUNNY_LIBRARY_ID=your_library_id_here

# ─── PAYSTACK ─────────────────────────────────────────────────────────────────
# Get from https://dashboard.paystack.com → Settings → API Keys
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_key_here
PAYSTACK_SECRET_KEY=sk_live_your_key_here

# Stripe was evaluated and removed — Nigerian-registered businesses can't open
# a standard Stripe merchant account (Nigeria is only in Stripe's "extended
# network" via the Paystack acquisition, not real Stripe access). Paystack
# already accepts international cards, so diaspora subscribers are covered.
# If payment-provider redundancy is ever needed later, Flutterwave was the
# researched fallback — supports direct Nigerian business registration while
# still processing international cards.

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://nollyvault.com
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
